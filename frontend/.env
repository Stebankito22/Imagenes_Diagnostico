# =====================================================
# CONFIGURACIÓN PARA RAILWAY
# =====================================================
# Estas variables se configuran en el dashboard de Railway:
# Settings → Variables

# 1. Base de datos (Railway PostgreSQL lo configura automáticamente)
#    DATABASE_URL → Se convierte automáticamente
#    ConnectionStrings__DefaultConnection → Se convierte automáticamente

# 2. Frontend API URL (en producción, el frontend está en el mismo servidor)
VITE_API_URL=

# =====================================================
# CONFIGURACIÓN DESARROLLO LOCAL
# =====================================================
VITE_API_IMAGENES=http://localhost:5211/api
VITE_API_PACIENTES=http://localhost:5001/api
VITE_API_CONSULTAS=http://localhost:5002/api
VITE_API_HOSPITALIZACION=http://localhost:5003/api
VITE_API_EMERGENCIAS=http://localhost:5004/api
VITE_API_FARMACIA=http://localhost:5005/api
VITE_API_INVENTARIOS=http://localhost:5006/api
VITE_API_FACTURACION=http://localhost:5007/api
VITE_API_ATENCION=http://localhost:5008/api
VITE_API_TELEMEDICINA=http://localhost:5009/api
VITE_API_RRHH=http://localhost:5010/api
